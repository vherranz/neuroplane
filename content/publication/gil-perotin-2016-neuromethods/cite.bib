@incollection{gil-perotin-2016-neuromethods,
 abstract = {The cloning of green fl uorescent protein (GFP) has opened a new arena of protein labeling and has become a new alternative to existing markers or dyes. Main advantages are its stability and its fl uorescent activity independent on the binding of other ligands or proteins. The use of GFP-tagged proteins has found multiple applications in molecular biology such as lineage tracing assays, cell fusion assessment, and/or immunodetection, among others. High-resolution imaging combined with immunogold labeling for GFP provides the best correlation with subcellular localization, and it allows detection of membranebound GFP-tagged receptors and cytosolic and/or nuclear proteins. In this chapter, we attempt to summarize the state-of-the-art in GFP detection, current protocols, advantages, and pitfalls, and we describe a method, used in our laboratory, which combines confocal fl uorescence microscopy with transmission electron microscopy (TEM) for the study of cell cultures at the ultrastructural level. © Springer Science+Business Media New York 2016.},
 address = {New York, NY},
 author = {Gil-Perotin, Sara and Cebrián-Silla, A and Herranz-Pérez, V and García-Belda, P and Gil-García, S and Fil, M and Lee, J S and Nachury, M V and García-Verdugo, José Manuel},
 booktitle = {Neuromethods},
 doi = {10.1007/978-1-4939-3064-7_14},
 keywords = {Correlative light and electron microscopy; Cre-recombinase; Fluorescent-tagged protein; High-resolution techniques; Pre-embedding immunogold labelling; green fluorescent protein; animal cell; animal tissue; cell culture; confocal fluorescence microscopy; controlled study; electron microscope; immunogold labeling; microscopy; mouse; nonhuman; priority journal; protein function; protein localization; protein secondary structure; transmission electron microscopy; ultrastructure;Mendeley Import (Dec 05);My papers},
 pages = {179--190},
 publisher = {Springer New York},
 series = {Neuromethods},
 title = {Localization of GFP-tagged proteins at the electron microscope},
 url = {https://doi.org/10.1007/978-1-4939-3064-7_14},
 volume = {110},
 year = {2016}
}
